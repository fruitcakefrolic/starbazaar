{
  "entities": {
    "application": {
      "title": "Maker Application",
      "description": "An application from a founding maker to join the Star Bazaar.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the applicant."
        },
        "makerName": {
          "type": "string",
          "description": "The name of the maker or brand."
        },
        "website": {
          "type": "string",
          "format": "uri",
          "description": "The maker's website or portfolio."
        },
        "socialHandle": {
          "type": "string",
          "description": "Optional TikTok or Instagram handle."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the application was submitted."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "reviewed", "accepted", "declined"],
          "description": "The current status of the application."
        }
      },
      "required": ["email", "makerName", "website", "createdAt", "status"]
    }
  },
  "firestore": {
    "/applications/{applicationId}": {
      "schema": "application",
      "description": "Collection of maker applications."
    }
  }
}
